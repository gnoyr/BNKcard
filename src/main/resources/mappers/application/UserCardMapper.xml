<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bnk.domain.application.mapper.UserCardMapper">

    <resultMap id="userCardMap" type="com.bnk.domain.application.model.UserCard">
        <id     property="userCardId"          column="user_card_id"/>
        <result property="userId"              column="user_id"/>
        <result property="cardId"              column="card_id"/>
        <result property="applicationId"       column="application_id"/>
        <result property="maskedCardNumber"    column="masked_card_number"/>
        <result property="cardNickname"        column="card_nickname"/>
        <result property="issueDate"           column="issue_date"/>
        <result property="expireDate"          column="expire_date"/>
        <result property="cardStatus"          column="card_status"/>
        <result property="usableYn"            column="usable_yn"/>
        <result property="dailyLimitAmount"    column="daily_limit_amount"/>
        <result property="monthlyLimitAmount"  column="monthly_limit_amount"/>
        <result property="overseasEnabledYn"   column="overseas_enabled_yn"/>
        <result property="contactlessEnabledYn" column="contactless_enabled_yn"/>
        <result property="issuedBy"            column="issued_by"/>
        <result property="issuedAt"            column="issued_at"/>
        <result property="updatedAt"           column="updated_at"/>
        <result property="deletedYn"           column="deleted_yn"/>
    </resultMap>

    <insert id="insertUserCard" useGeneratedKeys="true" keyProperty="userCardId">
        INSERT INTO USER_CARDS (
            user_id, card_id, application_id,
            masked_card_number, card_nickname,
            issue_date, expire_date,
            card_status, usable_yn,
            overseas_enabled_yn, contactless_enabled_yn,
            issued_by, issued_at, updated_at, deleted_yn
        ) VALUES (
            #{userId}, #{cardId},
            #{applicationId,       jdbcType=NUMERIC},
            #{maskedCardNumber},
            #{cardNickname,        jdbcType=VARCHAR},
            #{issueDate}, #{expireDate},
            #{cardStatus}, 'Y',
            'Y', 'Y',
            #{issuedBy, jdbcType=NUMERIC},
            SYSTIMESTAMP, SYSTIMESTAMP, 'N'
        )
    </insert>

    <select id="findByUserId" resultMap="userCardMap">
        SELECT * FROM USER_CARDS
        WHERE  user_id    = #{userId}
          AND  deleted_yn = 'N'
        ORDER  BY issued_at DESC
    </select>

    <update id="updateCardStatus">
        UPDATE USER_CARDS
        SET    card_status = #{cardStatus},
               updated_at  = SYSTIMESTAMP
        WHERE  user_card_id = #{userCardId}
    </update>

</mapper>
