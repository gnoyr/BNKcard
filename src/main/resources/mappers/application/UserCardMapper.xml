<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bnk.domain.application.mapper.UserCardMapper">

	<resultMap id="userCardMap" type="com.bnk.domain.application.model.UserCard">
	    <id     property="userCardId"           column="user_card_id"/>
	    <result property="userId"               column="user_id"/>
	    <result property="versionId"            column="version_id"/>
	    <result property="creditAppId"          column="credit_app_id"/>
	    <result property="checkAppId"           column="check_app_id"/>
	    <result property="cardPasswordHash"     column="card_password_hash"/>
	    <result property="cardNumber"           column="card_number"/>
	    <result property="issueDate"            column="issue_date"/>
	    <result property="expireDate"           column="expire_date"/>
	    <result property="cardStatus"           column="card_status"/>
	    <result property="usableYn"             column="usable_yn"/>
	    <result property="overseasEnabledYn"    column="overseas_enabled_yn"/>
	    <result property="contactlessEnabledYn" column="contactless_enabled_yn"/>
	    <result property="issuedAt"             column="issued_at"/>
	    <result property="updatedAt"            column="updated_at"/>
	    <result property="deletedYn"            column="deleted_yn"/>
	    <result property="deletedAt"            column="deleted_at"/>
	</resultMap>

	<!-- STEP 7,8 - APPROVED 시 자동 발급 -->
	<!-- card_password_hash: 서비스 레이어에서 BCrypt 해시 후 전달 -->
	<insert id="insertUserCard" useGeneratedKeys="false">
	    <selectKey keyProperty="userCardId" resultType="long" order="AFTER">
	        SELECT SEQ_USER_CARDS.CURRVAL FROM DUAL
	    </selectKey>
	    INSERT INTO USER_CARDS (
	        user_id, version_id,
	        credit_app_id, check_app_id,
	        card_password_hash,
	        card_number,
	        issue_date, expire_date,
	        card_status
	    ) VALUES (
	        #{userId}, #{versionId},
	        #{creditAppId, jdbcType=NUMERIC},
	        #{checkAppId,  jdbcType=NUMERIC},
	        #{cardPasswordHash},
	        #{cardNumber},
	        #{issueDate}, #{expireDate},
	        #{cardStatus}
	    )
	</insert>

    <select id="findByUserId" resultMap="userCardMap">
        SELECT * FROM USER_CARDS
        WHERE  user_id    = #{userId}
          AND  deleted_yn = 'N'
        ORDER  BY issued_at DESC
    </select>

    <update id="updateCardStatus">
        UPDATE USER_CARDS
        SET    card_status = #{cardStatus},
               updated_at  = SYSTIMESTAMP
        WHERE  user_card_id = #{userCardId}
    </update>

</mapper>