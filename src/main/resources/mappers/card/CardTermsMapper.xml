<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bnk.domain.card.mapper.CardTermsMapper">

    <resultMap id="cardTermsMap" type="com.bnk.domain.card.model.CardTerms">
        <id     property="cardTermsId"           column="card_terms_id" />
        <result property="cardId"                column="card_id" />
        <result property="termsId"               column="terms_id" />
        <result property="groupId"               column="group_id" />
        <result property="requiredYn"            column="required_yn"
            typeHandler="org.apache.ibatis.type.StringTypeHandler" />
        <result property="exposureConditionJson" column="exposure_condition_json" />
        <result property="displayOrder"          column="display_order" />
        <result property="createdAt"             column="created_at" />
        <result property="title"                 column="title"
            typeHandler="org.apache.ibatis.type.StringTypeHandler" />
        <result property="version"               column="version"
            typeHandler="org.apache.ibatis.type.StringTypeHandler" />
        <result property="contentHtml"           column="content_html" />
    </resultMap>

    <select id="findByCardId" resultMap="cardTermsMap">
        SELECT
            ct.card_terms_id,
            ct.card_id,
            ct.terms_id,
            ct.group_id,
            ct.required_yn,
            ct.exposure_condition_json,
            ct.display_order,
            ct.created_at,
            t.version,
            t.content_html,
            tm.title
        FROM CARD_TERMS ct
        JOIN TERMS t        ON ct.terms_id = t.terms_id
        JOIN TERMS_MASTERS tm ON t.terms_master_id = tm.terms_master_id
        WHERE ct.card_id = #{cardId}
        AND t.status = 'PUBLISHED'
        ORDER BY ct.display_order ASC NULLS LAST
    </select>

</mapper>