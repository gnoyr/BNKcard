<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bnk.domain.card.mapper.CardContentMapper">

	<resultMap id="contentMap"
		type="com.bnk.domain.card.model.CardContent">
		<id property="contentId" column="content_id" />
		<result property="cardId" column="card_id" />
		<result property="contentType" column="content_type"
			typeHandler="org.apache.ibatis.type.StringTypeHandler" />
		<result property="title" column="title"
			typeHandler="org.apache.ibatis.type.StringTypeHandler" />
		<result property="contentHtml" column="content_html"
			jdbcType="CLOB" typeHandler="org.apache.ibatis.type.ClobTypeHandler" />
		<result property="mobileContentHtml"
			column="mobile_content_html" jdbcType="CLOB"
			typeHandler="org.apache.ibatis.type.ClobTypeHandler" />
		<result property="displayOrder" column="display_order" />
		<result property="visibleYn" column="visible_yn"
			typeHandler="org.apache.ibatis.type.StringTypeHandler" />
		<result property="createdBy" column="created_by" />
		<result property="createdAt" column="created_at" />
		<result property="updatedAt" column="updated_at" />
	</resultMap>

	<select id="findByCardId" resultMap="contentMap">
		SELECT *
		FROM CARD_CONTENTS
		WHERE card_id = #{cardId}
		AND visible_yn = 'Y'
		ORDER BY display_order
		ASC NULLS LAST
	</select>

	<insert id="insertContents">
		INSERT INTO CARD_CONTENTS (
		card_id, content_type, title,
		content_html,
		mobile_content_html,
		display_order, visible_yn, created_by, created_at
		)
		<foreach collection="contentList" item="c"
			separator=" UNION ALL ">
			SELECT
			#{c.cardId},
			#{c.contentType},
			#{c.title},
			#{c.contentHtml, jdbcType=CLOB},
			#{c.mobileContentHtml,
			jdbcType=CLOB},
			#{c.displayOrder, jdbcType=NUMERIC},
			NVL(#{c.visibleYn, jdbcType=CHAR}, 'Y'),
			#{c.createdBy,
			jdbcType=NUMERIC},
			SYSTIMESTAMP
			FROM DUAL
		</foreach>
	</insert>

	<delete id="deleteByCardId">
		DELETE FROM CARD_CONTENTS
		WHERE card_id = #{cardId}
	</delete>

</mapper>