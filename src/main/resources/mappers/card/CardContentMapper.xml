<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bnk.domain.card.mapper.CardContentMapper">

    <select id="findByCardId"
            resultType="com.bnk.domain.card.model2.CardContent">
        SELECT *
        FROM CARD_CONTENT
        WHERE card_id = #{cardId}
        AND visible_yn = 'Y'
        ORDER BY display_order ASC NULLS LAST
    </select>

</mapper>